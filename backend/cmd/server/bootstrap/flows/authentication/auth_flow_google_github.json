{
    "name": "Default Google + GitHub Authentication Flow",
    "handle": "default-google-github-flow",
    "flowType": "AUTHENTICATION",
    "nodes": [
        {
            "id": "start",
            "type": "START",
            "onSuccess": "choose_auth"
        },
        {
            "id": "choose_auth",
            "type": "PROMPT",
            "meta": {
                "components": [
                    {
                        "alt": "{{ t(signin:images.app_logo.alt) }}",
                        "category": "DISPLAY",
                        "height": "60",
                        "id": "image",
                        "resourceType": "ELEMENT",
                        "src": "{{ meta(application.logo_url) }}",
                        "type": "IMAGE",
                        "width": ""
                    },
                    {
                        "align": "center",
                        "type": "TEXT",
                        "id": "text_001",
                        "label": "{{ t(signin:forms.choose_auth_method.title) }}",
                        "variant": "HEADING_1"
                    },
                    {
                        "type": "BLOCK",
                        "id": "block_google",
                        "components": [
                            {
                                "type": "ACTION",
                                "id": "action_google",
                                "label": "{{ t(signin:forms.choose_auth_method.actions.google.label) }}",
                                "variant": "PRIMARY",
                                "eventType": "SUBMIT"
                            }
                        ]
                    },
                    {
                        "type": "BLOCK",
                        "id": "block_github",
                        "components": [
                            {
                                "type": "ACTION",
                                "id": "action_github",
                                "label": "{{ t(signin:forms.choose_auth_method.actions.github.label) }}",
                                "variant": "SECONDARY",
                                "eventType": "SUBMIT"
                            }
                        ]
                    }
                ]
            },
            "prompts": [
                {
                    "action": {
                        "ref": "action_google",
                        "nextNode": "google_auth"
                    }
                },
                {
                    "action": {
                        "ref": "action_github",
                        "nextNode": "github_auth"
                    }
                }
            ]
        },
        {
            "id": "google_auth",
            "type": "TASK_EXECUTION",
            "properties": {
                "idpId": "<google-idp-id>"
            },
            "executor": {
                "name": "GoogleOIDCAuthExecutor",
                "inputs": [
                    {
                        "ref": "input_003",
                        "type": "TEXT_INPUT",
                        "identifier": "code",
                        "required": true
                    }
                ]
            },
            "onSuccess": "auth_assert"
        },
        {
            "id": "github_auth",
            "type": "TASK_EXECUTION",
            "properties": {
                "idpId": "<github-idp-id>"
            },
            "executor": {
                "name": "GithubOAuthExecutor",
                "inputs": [
                    {
                        "ref": "input_004",
                        "type": "TEXT_INPUT",
                        "identifier": "code",
                        "required": true
                    }
                ]
            },
            "onSuccess": "auth_assert"
        },
        {
            "id": "auth_assert",
            "type": "TASK_EXECUTION",
            "executor": {
                "name": "AuthAssertExecutor"
            },
            "onSuccess": "end"
        },
        {
            "id": "end",
            "type": "END"
        }
    ]
}
