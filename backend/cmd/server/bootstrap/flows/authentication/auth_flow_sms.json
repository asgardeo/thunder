{
    "name": "Default SMS OTP Authentication Flow",
    "handle": "default-sms-otp-flow",
    "flowType": "AUTHENTICATION",
    "nodes": [
        {
            "id": "start",
            "type": "START",
            "onSuccess": "prompt_mobile"
        },
        {
            "id": "prompt_mobile",
            "type": "PROMPT",
            "meta": {
                "components": [
                    {
                        "alt": "{{ t(signin:images.app_logo.alt) }}",
                        "category": "DISPLAY",
                        "height": "60",
                        "id": "image",
                        "resourceType": "ELEMENT",
                        "src": "{{ meta(application.logo_url) }}",
                        "type": "IMAGE",
                        "width": ""
                    },
                    {
                        "align": "center",
                        "type": "TEXT",
                        "id": "text_mobile",
                        "label": "{{ t(signin:forms.mobile_number.title) }}",
                        "variant": "HEADING_1"
                    },
                    {
                        "type": "BLOCK",
                        "id": "block_mobile",
                        "components": [
                            {
                                "id": "input_mobile",
                                "ref": "mobileNumber",
                                "type": "PHONE_INPUT",
                                "label": "{{ t(signin:forms.mobile_number.fields.mobile.label) }}",
                                "required": true,
                                "placeholder": "{{ t(signin:forms.mobile_number.fields.mobile.placeholder) }}"
                            },
                            {
                                "type": "ACTION",
                                "id": "action_send_sms",
                                "label": "{{ t(signin:forms.mobile_number.actions.submit.label) }}",
                                "variant": "PRIMARY",
                                "eventType": "SUBMIT"
                            }
                        ]
                    }
                ]
            },
            "prompts": [
                {
                    "inputs": [
                        {
                            "ref": "input_mobile",
                            "identifier": "mobileNumber",
                            "type": "PHONE_INPUT",
                            "required": true
                        }
                    ],
                    "action": {
                        "ref": "action_send_sms",
                        "nextNode": "send_sms"
                    }
                }
            ]
        },
        {
            "id": "send_sms",
            "type": "TASK_EXECUTION",
            "properties": {
                "senderId": "<your-sender-id>"
            },
            "executor": {
                "name": "SMSOTPAuthExecutor",
                "mode": "send"
            },
            "onSuccess": "prompt_otp"
        },
        {
            "id": "prompt_otp",
            "type": "PROMPT",
            "meta": {
                "components": [
                    {
                        "alt": "{{ t(signin:images.app_logo.alt) }}",
                        "category": "DISPLAY",
                        "height": "60",
                        "id": "image",
                        "resourceType": "ELEMENT",
                        "src": "{{ meta(application.logo_url) }}",
                        "type": "IMAGE",
                        "width": ""
                    },
                    {
                        "align": "center",
                        "type": "TEXT",
                        "id": "text_otp",
                        "label": "{{ t(signin:forms.otp.title) }}",
                        "variant": "HEADING_1"
                    },
                    {
                        "type": "BLOCK",
                        "id": "block_otp",
                        "components": [
                            {
                                "id": "input_otp",
                                "ref": "otp",
                                "type": "OTP_INPUT",
                                "label": "{{ t(signin:forms.otp.fields.otp.label) }}",
                                "required": true,
                                "placeholder": "{{ t(signin:forms.otp.fields.otp.placeholder) }}"
                            },
                            {
                                "type": "ACTION",
                                "id": "action_verify_otp",
                                "label": "{{ t(signin:forms.otp.actions.submit.label) }}",
                                "variant": "PRIMARY",
                                "eventType": "SUBMIT"
                            }
                        ]
                    }
                ]
            },
            "prompts": [
                {
                    "inputs": [
                        {
                            "ref": "input_otp",
                            "identifier": "otp",
                            "type": "OTP_INPUT",
                            "required": true
                        }
                    ],
                    "action": {
                        "ref": "action_verify_otp",
                        "nextNode": "verify_sms"
                    }
                }
            ]
        },
        {
            "id": "verify_sms",
            "type": "TASK_EXECUTION",
            "properties": {
                "senderId": "<your-sender-id>"
            },
            "executor": {
                "name": "SMSOTPAuthExecutor",
                "mode": "verify"
            },
            "onSuccess": "auth_assert"
        },
        {
            "id": "auth_assert",
            "type": "TASK_EXECUTION",
            "executor": {
                "name": "AuthAssertExecutor"
            },
            "onSuccess": "end"
        },
        {
            "id": "end",
            "type": "END"
        }
    ]
}
